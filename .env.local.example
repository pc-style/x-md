# Optional scrape fallbacks when FxTwitter/syndication fail (local/self-host only)
# Do not set on Vercel Production for the public x-md deploy unless you want paid fallbacks enabled there
CONTEXT_DEV_API_KEY=
FIRECRAWL_API_KEY=

# Converter cache (optional)
CACHE_TTL_SECONDS=3600
# CACHE_DISABLED=1
# CACHE_PERSIST=0

# Premium monetization (Autumn + Stripe, Clerk, Convex)
# Clerk publishable key is safe for browser use; all other keys stay server-side.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
CONVEX_SERVER_SECRET=
AUTUMN_SECRET_KEY=
AUTUMN_WEBHOOK_SECRET=
